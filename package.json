{
  "name": "whui-client",
  "version": "0.1.5",
  "exports": {
    ".": {
      "types": "./dist/api-client/index.d.ts",
      "default": "./dist/api-client/index.js"
    }
  },
  "files": ["dist/api-client"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",

    "api:clean:dist": "rimraf dist",
    "api:clean": "rimraf /src/api-client",
    "api:gen": "openapi-generator-cli generate -i ./api-docs.yaml -g typescript-angular -o ./src/api-client --skip-validate-spec --additional-properties=providedInRoot=true,fileNaming=kebab-case",
    "api:clean:gen": "npm run api:clean && npm run api:gen"
  },
  "private": false,
  "dependencies": {
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/file-saver": "^2.0.7",
    "file-saver": "^2.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript-collections": "^1.3.3",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "typescript": "~5.5.2",
    "typescript-eslint": "8.46.4",
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "rimraf": "^6.1.2"
  }
}
